<%# Page pour renvoyer les instructions de confirmation d'e-mail.
    Affiché quand l'utilisateur n'a pas reçu ou a perdu l'e-mail de confirmation. %>

<div class="devise-page">
  <div class="devise-card">

    <div class="devise-header">
      <%= link_to root_path, class: "devise-logo" do %>
        <span class="move">Move</span> <span class="on">On</span>
      <% end %>
      <h1 class="devise-title">Confirmer mon e-mail</h1>
      <p class="devise-subtitle">Vous n'avez pas reçu l'e-mail de confirmation ?</p>
      <div class="devise-divider"></div>
    </div>

    <%= simple_form_for(resource, as: resource_name,
                        url: confirmation_path(resource_name),
                        html: { method: :post }) do |f| %>
      <%= f.error_notification %>
      <%= f.full_error :confirmation_token %>

      <div class="form-inputs">
        <%# Si un e-mail est en attente de reconfirmation (changement d'adresse),
            on pré-remplit le champ avec la nouvelle adresse non confirmée. %>
        <%= f.input :email,
                    label: "Adresse e-mail",
                    required: true,
                    autofocus: true,
                    value: (resource.pending_reconfirmation? ? resource.unconfirmed_email : resource.email),
                    input_html: { autocomplete: "email" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Renvoyer les instructions", class: "btn-devise-primary" %>
      </div>

    <% end %>

    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
