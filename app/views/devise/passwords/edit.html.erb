<%# Page de saisie du nouveau mot de passe — accessible via le lien envoyé par e-mail.
    Le token de réinitialisation est transmis en champ caché (as: :hidden). %>

<div class="devise-page">
  <div class="devise-card">

    <div class="devise-header">
      <%= link_to root_path, class: "devise-logo" do %>
        <span class="move">Move</span> <span class="on">On</span>
      <% end %>
      <h1 class="devise-title">Nouveau mot de passe</h1>
      <p class="devise-subtitle">Choisissez un mot de passe sécurisé.</p>
      <div class="devise-divider"></div>
    </div>

    <%= simple_form_for(resource, as: resource_name,
                        url: password_path(resource_name),
                        html: { method: :put }) do |f| %>
      <%= f.error_notification %>

      <%# Champ caché obligatoire : il contient le token unique de réinitialisation
          transmis dans l'URL de l'e-mail. Sans lui, Devise refuse la mise à jour. %>
      <%= f.input :reset_password_token, as: :hidden %>
      <%= f.full_error :reset_password_token %>

      <div class="form-inputs">
        <%= f.input :password,
                    label: "Nouveau mot de passe",
                    required: true,
                    autofocus: true,
                    hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                    input_html: { autocomplete: "new-password" } %>

        <%= f.input :password_confirmation,
                    label: "Confirmez le nouveau mot de passe",
                    required: true,
                    input_html: { autocomplete: "new-password" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Enregistrer le mot de passe", class: "btn-devise-primary" %>
      </div>

    <% end %>

    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
