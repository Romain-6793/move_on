<%# Page "Mot de passe oublié" — l'utilisateur saisit son email pour
    recevoir un lien de réinitialisation par e-mail. %>

<div class="devise-page">
  <div class="devise-card">

    <div class="devise-header">
      <%= link_to root_path, class: "devise-logo" do %>
        <span class="move">Move</span> <span class="on">On</span>
      <% end %>
      <h1 class="devise-title">Mot de passe oublié ?</h1>
      <p class="devise-subtitle">Nous vous enverrons un lien de réinitialisation par e-mail.</p>
      <div class="devise-divider"></div>
    </div>

    <%= simple_form_for(resource, as: resource_name,
                        url: password_path(resource_name),
                        html: { method: :post }) do |f| %>
      <%= f.error_notification %>

      <div class="form-inputs">
        <%= f.input :email,
                    label: "Adresse e-mail",
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Envoyer les instructions", class: "btn-devise-primary" %>
      </div>

    <% end %>

    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
