<%# Page de connexion Devise.
    La card est étroite (max-width 480px) car on ne demande que deux champs.
    Le fond dégradé vert/bleu est défini dans pages/_devise.scss (.devise-page). %>

<div class="devise-page">
  <div class="devise-card">

    <%# En-tête : logo bicolore Move On + titre + barre verte décorative %>
    <div class="devise-header">
      <%= link_to root_path, class: "devise-logo" do %>
        <span class="move">Move</span> <span class="on">On</span>
      <% end %>
      <h1 class="devise-title">Connexion</h1>
      <p class="devise-subtitle">Content·e de vous revoir !</p>
      <div class="devise-divider"></div>
    </div>

    <%# simple_form_for génère le formulaire avec protection CSRF automatique.
        resource et resource_name sont des helpers Devise disponibles dans toutes ses vues. %>
    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

      <div class="form-inputs">
        <%= f.input :email,
                    label: "Adresse e-mail",
                    required: false,
                    autofocus: true,
                    input_html: { autocomplete: "email" } %>

        <%= f.input :password,
                    label: "Mot de passe",
                    required: false,
                    input_html: { autocomplete: "current-password" } %>

        <%# remember_me n'est affiché que si le modèle User inclut le module :rememberable %>
        <%= f.input :remember_me,
                    label: "Se souvenir de moi",
                    as: :boolean if devise_mapping.rememberable? %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Se connecter", class: "btn-devise-primary" %>
      </div>

    <% end %>

    <%# Liens vers les autres pages Devise (inscription, mot de passe oublié…) %>
    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
