<%# Partial partagé par toutes les pages Devise pour afficher les liens de navigation
    secondaires (connexion, inscription, mot de passe oublié, etc.).
    Chaque lien est conditionnel : il n'apparaît pas sur la page qui lui correspond
    (pas de "Connexion" sur la page de connexion) pour éviter la confusion. %>

<%- if controller_name != 'sessions' %>
  <%= link_to "Déjà un compte ? Se connecter", new_session_path(resource_name) %>
<% end %>

<%- if devise_mapping.registerable? && controller_name != 'registrations' %>
  <%= link_to "Pas encore de compte ? S'inscrire", new_registration_path(resource_name) %>
<% end %>

<%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
  <%= link_to "Mot de passe oublié ?", new_password_path(resource_name) %>
<% end %>

<%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
  <%= link_to "E-mail de confirmation non reçu ?", new_confirmation_path(resource_name) %>
<% end %>

<%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
  <%= link_to "Instructions de déverrouillage non reçues ?", new_unlock_path(resource_name) %>
<% end %>

<%- if devise_mapping.omniauthable? %>
  <%- resource_class.omniauth_providers.each do |provider| %>
    <%= button_to "Continuer avec #{OmniAuth::Utils.camelize(provider)}",
                  omniauth_authorize_path(resource_name, provider),
                  data: { turbo: false } %>
  <% end %>
<% end %>
