<%# Page pour déverrouiller un compte bloqué après trop de tentatives de connexion.
    Devise bloque un compte après un nombre configurable d'échecs (module :lockable). %>

<div class="devise-page">
  <div class="devise-card">

    <div class="devise-header">
      <%= link_to root_path, class: "devise-logo" do %>
        <span class="move">Move</span> <span class="on">On</span>
      <% end %>
      <h1 class="devise-title">Compte verrouillé</h1>
      <p class="devise-subtitle">Renvoyez les instructions de déverrouillage par e-mail.</p>
      <div class="devise-divider"></div>
    </div>

    <%= simple_form_for(resource, as: resource_name,
                        url: unlock_path(resource_name),
                        html: { method: :post }) do |f| %>
      <%= f.error_notification %>
      <%= f.full_error :unlock_token %>

      <div class="form-inputs">
        <%= f.input :email,
                    label: "Adresse e-mail",
                    required: true,
                    autofocus: true,
                    input_html: { autocomplete: "email" } %>
      </div>

      <div class="form-actions">
        <%= f.button :submit, "Renvoyer les instructions", class: "btn-devise-primary" %>
      </div>

    <% end %>

    <div class="devise-links">
      <%= render "devise/shared/links" %>
    </div>

  </div>
</div>
