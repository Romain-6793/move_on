<!DOCTYPE html>
<html>
  <head>
    <title>Move On – Trouvez la ville qui vous correspond</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Move On">
    <meta property="og:title" content="Move On – Trouvez la ville qui vous correspond">
    <meta property="og:description" 
    content="En 3 étapes simples, trouvez la ville idéale pour vous installer selon vos critères">
    <meta property="og:image" content="<%= image_url('rectangle_logo_og.png') %>">
    <meta property="og:url" content="https://www.moveonfrance.me">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%#
      Favicons Move On – stratégie multi-format :
      - SVG  : navigateurs modernes (Chrome 80+, Firefox, Safari 13+) — vectoriel, toujours net
      - PNG 16/32 : navigateurs récents qui ne lisent pas le SVG
      - ICO  : fallback universel (IE, anciens Chromium) ; placé en dernier car priorité basse
      - apple-touch-icon : iOS — icône écran d'accueil / PWA (180×180 requis par Apple)
      - android-chrome   : Android / PWA manifest
      Les PNG et ICO sont dans public/ (servis statiquement, sans asset pipeline).
    %>
    <%= favicon_link_tag 'favicon.svg', rel: 'icon', type: 'image/svg+xml' %>
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="shortcut icon" href="/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="192x192" href="/android-chrome-192x192.png">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%# Permet aux vues d'injecter des balises <link> ou <script> supplémentaires dans le <head>.
        Utilisé par exemple pour charger Mapbox GL JS uniquement sur la page carte. %>
    <%= yield :head %>
  </head>
  <body>
    <%# Lien d'accessibilité pour sauter la navigation (utilisateurs clavier/lecteurs d'écran) %>
    <%= link_to "Aller au contenu principal", "#main-content", class: "visually-hidden-focusable" %>
    <header>
      <%= render "shared/navbar" %>
    </header>
    <main id="main-content">
      <%# Les flashes sont affichés avant le contenu de la page pour être vus immédiatement %>
      <%= render "shared/flashes" %>
      <%= yield %>
    </main>
    <%# Footer commun à toutes les pages %>
    <%= render "shared/footer" %>
    <%= render "shared/chatbot_widget" %>
  </body>
</html>
