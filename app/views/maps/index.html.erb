<% content_for :head do %>
  <%# Turbo Drive injecte les scripts <head> dynamiquement lors des navigations,
      ce qui crée une race condition : Stimulus se connecte avant que mapboxgl soit chargé.
      "reload" force un rechargement complet de la page, garantissant l'ordre d'exécution
      synchrone : Mapbox se charge avant que le module Stimulus ne s'initialise. %>
  <meta name="turbo-visit-control" content="reload">
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.css" rel="stylesheet" />
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.js"></script>
<% end %>

<div class="map-page">
  <div class="map-page__sidebar">
    <h1 class="map-page__title">Trouver sur la carte</h1>
    <p class="map-page__description">
      Explorez les villes et leurs points d'intérêt. Cliquez sur un point pour en savoir plus.
    </p>

    <%# Légende des layers ─────────────────────────────────────────────────── %>
    <div class="map-legend">
      <h2 class="map-legend__title">Légende</h2>

      <section class="map-legend__section">
        <h3 class="map-legend__subtitle">Villes — score global</h3>
        <ul class="map-legend__list">
          <li><span class="map-legend__dot" style="background:#7CB342"></span> Score élevé (7–10)</li>
          <li><span class="map-legend__dot" style="background:#FFCA28"></span> Score moyen (4–6)</li>
          <li><span class="map-legend__dot" style="background:#e74c3c"></span> Score faible (0–3)</li>
          <li class="map-legend__note">La taille du cercle reflète aussi le score.</li>
        </ul>
      </section>

      <section class="map-legend__section">
        <h3 class="map-legend__subtitle">Points d'intérêt</h3>
        <ul class="map-legend__list">
          <li><span class="map-legend__dot" style="background:#7CB342"></span> Sport</li>
          <li><span class="map-legend__dot" style="background:#4FC3F7"></span> Culture</li>
          <li><span class="map-legend__dot" style="background:#558B2F"></span> Nature</li>
          <li><span class="map-legend__dot" style="background:#FFCA28"></span> Commerce</li>
          <li><span class="map-legend__dot" style="background:#0288D1"></span> Transport</li>
          <li><span class="map-legend__dot" style="background:#8D6E63"></span> Éducation</li>
          <li><span class="map-legend__dot" style="background:#2E9EAD"></span> Santé</li>
        </ul>
        <p class="map-legend__note">
          Les cercles bleus sont des groupes — cliquez pour zoomer et les éclater.
        </p>
      </section>
    </div>
  </div>

  <%# data-map-data-url-value : URL de l'endpoint JSON, construite par Rails pour éviter tout hardcoding.
      Le Stimulus controller la lit via this.dataUrlValue et y fait un fetch(). %>
  <div
    id="map"
    class="map-page__map"
    data-controller="map"
    data-map-token-value="<%= ENV.fetch('MAPBOX_API_KEY', '') %>"
    data-map-lat-value="46.6034"
    data-map-lng-value="1.8883"
    data-map-zoom-value="5"
    data-map-data-url-value="<%= maps_path(format: :json) %>"
  ></div>
</div>
