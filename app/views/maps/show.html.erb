<% content_for :head do %>
  <%# Même stratégie que maps/index.html.erb : reload complet pour éviter la race condition
      entre le script Mapbox (CDN synchrone) et l'initialisation Stimulus. %>
  <meta name="turbo-visit-control" content="reload">
  <link href="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.css" rel="stylesheet" />
  <script src="https://api.mapbox.com/mapbox-gl-js/v3.11.0/mapbox-gl.js"></script>
<% end %>

<div class="map-page">
  <div class="map-page__sidebar">
    <h1 class="map-page__title"><%= @city.nom_com %></h1>
    <p class="map-page__description">
      <%= [@city.nom_dep, @city.nom_reg].compact.join(" · ") %>
    </p>

    <%# Lien retour — history.back() permet de revenir à la page précédente (résultats ou carte résultats) %>
    <a href="javascript:history.back()" class="map-page__back-link">
      ← Retour
    </a>
  </div>

  <%#
    Conteneur Mapbox — piloté par map_controller.js.

    Choix produit : on n'affiche plus les pastilles des critères essentiels autour de
    la ville ni la légende associée — la carte reste visuellement épurée et ne montre
    que le marqueur de la ville ciblée.
  %>
  <%#
    data-map-rank-value : rang (1..5) transmis via le query param ?rank=
    dans maps#show. Utilisé par map_controller.js pour afficher un marqueur
    personnalisé (pastille colorée + chiffre) identique à celui de la carte
    des 5 résultats. Sans rang → marqueur Mapbox par défaut (fallback).
  %>
  <div
    id="map"
    class="map-page__map"
    data-controller="map"
    data-map-token-value="<%= ENV.fetch('MAPBOX_API_KEY', '') %>"
    data-map-lat-value="<%= @city.latitude %>"
    data-map-lng-value="<%= @city.longitude %>"
    data-map-zoom-value="13"
    data-map-city-name-value="<%= @city.nom_com %>"
    data-map-rank-value="<%= @city_rank || 0 %>"
    data-map-geolocate-value="false"
  ></div>
</div>
