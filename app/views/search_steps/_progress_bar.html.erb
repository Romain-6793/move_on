<%#
  Partial : barre de progression du wizard de recherche.

  Locals attendus :
    current_step  – Integer : numéro de l'étape courante (1..4)
    total_steps   – Integer : nombre total d'étapes
    step_labels   – Array<String> : libellés des étapes dans l'ordre

  Couleurs (charte Move On) :
    - Étape complétée  → var(--green-primary) #7CB342
    - Étape courante   → var(--blue-dark)     #0288D1
    - Étape future     → var(--gray-300)      #E0E0E0
%>
<div class="wizard-progress" aria-label="Progression du formulaire">
  <% step_labels.each_with_index do |label, i| %>
    <% step_number = i + 1 %>
    <%#
      On détermine l'état CSS de chaque pastille :
        "completed" si l'étape est déjà passée
        "current"   si c'est l'étape affichée
        "upcoming"  si l'étape n'est pas encore atteinte
    %>
    <% state = if step_number < current_step then 'completed'
                elsif step_number == current_step then 'current'
                else 'upcoming' end %>

    <%# Trait de connexion entre les pastilles (pas avant la première) %>
    <% if i > 0 %>
      <div class="wizard-progress-line wizard-progress-line--<%= step_number <= current_step ? 'done' : 'todo' %>"></div>
    <% end %>

    <div class="wizard-progress-step wizard-progress-step--<%= state %>"
         aria-current="<%= 'step' if state == 'current' %>">
      <div class="wizard-progress-dot">
        <% if state == 'completed' %>
          <%# Coche pour les étapes terminées — icône Font Awesome %>
          <i class="fas fa-check" aria-hidden="true"></i>
        <% else %>
          <%= step_number %>
        <% end %>
      </div>
      <span class="wizard-progress-label"><%= label %></span>
    </div>
  <% end %>
</div>

<%# Texte "Étape N sur N" accessible aux lecteurs d'écran et visible sur mobile %>
<p class="wizard-step-counter" aria-live="polite">
  Étape <%= current_step %> sur <%= total_steps %>
</p>
