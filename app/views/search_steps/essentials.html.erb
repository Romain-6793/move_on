<%#
  Wizard – Étape 2 : Critères essentiels
  ────────────────────────────────────────
  L'utilisateur sélectionne jusqu'à 3 critères qu'il juge indispensables.
  Chaque critère coché reçoit la valeur 3 (="essentiel") en base.
  Les critères non cochés sont mis à 0 ("non retenu").

  Le contrôleur Stimulus "wizard-essentials" :
    - Compte les critères cochés et bloque à 3
    - Affiche un message quand la limite est atteinte
    - Gère la spécificité Éducation (sélection des niveaux scolaires)
%>
<%#
  Mapping critères → icônes Font Awesome + couleur de la bande.
  Défini ici (vue) plutôt que dans le contrôleur car c'est purement présentationnel.
%>
<% wizard_criteria = [
  { key: 'real_estate',         title: 'Bons plans immobiliers',  icon: 'fa-house',           color: '#8D6E63' },
  { key: 'transport_network',   title: 'Qualité des transports',  icon: 'fa-train',           color: '#2E9EAD' },
  { key: 'health',              title: 'Accès aux soins',         icon: 'fa-stethoscope',     color: '#F48FB1' },
  { key: 'commercial_life',     title: 'Vie commerciale',         icon: 'fa-store',           color: '#FFB74D' },
  { key: 'cultural_heritage',   title: 'Culture et patrimoine',   icon: 'fa-landmark',        color: '#9575CD' },
  { key: 'leisures_and_sports', title: 'Sports et loisirs',       icon: 'fa-dumbbell',        color: '#E57373' },
  { key: 'outdoor_living',      title: 'Vie au grand air',        icon: 'fa-tree',            color: '#558B2F' },
  { key: 'sunshine',            title: 'Ville ensoleillée',       icon: 'fa-sun',             color: '#FFCA28' },
  { key: 'job_market',          title: 'Ville d\'emploi',         icon: 'fa-briefcase',       color: '#B3E5FC' },
  { key: 'near_big_city',       title: 'Proche d\'une métropole', icon: 'fa-city',            color: '#FF8A65' },
  { key: 'education',           title: 'Éducation',               icon: 'fa-graduation-cap',  color: '#0288D1' },
] %>
<div class="search-wizard-page search-background">
  <%= render 'progress_bar',
        current_step: 2,
        total_steps:  4,
        step_labels:  ['Votre projet', 'Critères essentiels', 'Priorités', 'Récapitulatif'] %>
  <div class="wizard-card"
       data-controller="wizard-essentials"
       data-wizard-essentials-limit-value="3">
    <div class="wizard-card-header">
      <h1 class="wizard-card-title">
        <i class="fas fa-star wizard-title-icon" aria-hidden="true"></i>
        Critères essentiels
      </h1>
      <p class="wizard-card-subtitle">
        Choisissez <strong>jusqu'à 3 critères</strong> qui sont absolument indispensables
        pour vous. Ce seront les critères les plus valorisés dans le calcul.
      </p>
      <%# Compteur de sélections — mis à jour par Stimulus %>
      <div class="wizard-essentials-counter">
        <span data-wizard-essentials-target="count">
          <%= wizard_criteria.count { |c| @research.send(c[:key]) == 3 } %>
        </span>/3 critères essentiels sélectionnés
      </div>
      <%# Message d'alerte affiché quand la limite est atteinte, caché par défaut %>
      <div class="wizard-limit-alert" data-wizard-essentials-target="limitAlert" hidden>
        <i class="fas fa-exclamation-triangle" aria-hidden="true"></i>
        Limite de 3 critères essentiels atteinte. Décochez-en un pour en sélectionner un autre.
      </div>
    </div>
    <%= form_with url: wizard_path, method: :patch, html: { class: 'wizard-form' } do |f| %>
      <div class="wizard-criteria-grid">
        <% wizard_criteria.each do |criterion| %>
          <%#
            Pour chaque critère, un checkbox "Essentiel?" et les champs cachés.
            is_essential : vrai si la valeur en base vaut 3 (ce critère était essentiel)
          %>
          <% is_essential = @research.send(criterion[:key]) == 3 %>
          <div class="wizard-criterion-card"
               style="--card-color: <%= criterion[:color] %>"
               data-wizard-essentials-target="card"
               data-criterion="<%= criterion[:key] %>">
            <%# Bandeau coloré en haut — repère visuel rapide %>
            <div class="wizard-criterion-band"></div>
            <div class="wizard-criterion-body">
              <div class="wizard-criterion-header">
                <i class="fas <%= criterion[:icon] %> wizard-criterion-icon"
                   style="color: <%= criterion[:color] %>"
                   aria-hidden="true"></i>
                <p class="wizard-criterion-title"><%= criterion[:title] %></p>
              </div>
              <%# ── Accordéon "En savoir plus" ───────────────────────────────
                  Explique à l'utilisateur comment le score est calculé pour ce
                  critère. Utilise l'élément natif <details>/<summary> : pas
                  besoin de JS, l'ouverture/fermeture est gérée par le navigateur,
                  et c'est accessible aux lecteurs d'écran par défaut.
                  La description vient du helper criterion_description (source
                  unique dans ApplicationHelper) pour éviter la duplication. %>
              <details class="wizard-criterion-info">
                <summary class="wizard-criterion-info-btn">En savoir plus</summary>
                <p class="wizard-criterion-info-description">
                  <%= criterion_description(criterion[:key]) %>
                </p>
              </details>
              <%# Bloc spécifique Éducation : choix des niveaux scolaires %>
              <% if criterion[:key] == 'education' %>
                <div class="wizard-education-block"
                     data-wizard-essentials-target="educationBlock">
                  <p class="wizard-education-label">Niveaux scolaires souhaités</p>
                  <div class="wizard-education-tags"
                       data-wizard-essentials-target="educationTagsDisplay">
                    <%# Tags injectés dynamiquement par Stimulus %>
                  </div>
                  <div class="wizard-education-controls">
                    <select data-wizard-essentials-target="educationSelect"
                            class="wizard-education-select">
                      <option value="">Choisir un niveau…</option>
                      <option value="Petite enfance" <%= 'disabled' if (@research.education_levels || []).include?('Petite enfance') %>>Petite enfance (crèches, EAJE)</option>
                      <option value="Premier degré"  <%= 'disabled' if (@research.education_levels || []).include?('Premier degré') %>>Premier degré (écoles maternelles et élémentaires)</option>
                      <option value="Second degré"   <%= 'disabled' if (@research.education_levels || []).include?('Second degré') %>>Second degré (collèges et lycées)</option>
                    </select>
                    <button type="button"
                            class="wizard-education-add-btn"
                            data-action="click->wizard-essentials#addEducationTag">
                      <i class="fas fa-plus" aria-hidden="true"></i>
                      Ajouter
                    </button>
                  </div>
                  <%# Champ caché JSON — rempli par Stimulus, soumis avec le formulaire %>
                  <input type="hidden"
                         name="research[education_levels]"
                         value="<%= (@research.education_levels || []).to_json %>"
                         data-wizard-essentials-target="educationHidden">
                      </div>
                    <% end %>
                  </div>
                  <%# Footer : checkbox de sélection "Essentiel" %>
                  <div class="wizard-criterion-footer">
                    <label class="wizard-checkbox-label <%= 'wizard-checkbox-disabled' if criterion[:key] == 'education' && (@research.education_levels || []).empty? %>">
                      <input type="checkbox"
                       class="wizard-criterion-checkbox"
                       data-action="change->wizard-essentials#toggleEssential"
                      data-criterion="<%= criterion[:key] %>"
                      <%= 'checked' if is_essential %>
                      <%= 'disabled' if criterion[:key] == 'education' && (@research.education_levels || []).empty? %>
                      data-wizard-essentials-target="<%= 'educationCheckbox' if criterion[:key] == 'education' %>">
                      <span class="wizard-checkbox-text">Essentiel pour moi</span>
                    </label>
                  </div>
                  <%#
              Champ caché soumis avec le formulaire.
              Valeur 3 si essentiel, 0 sinon.
              Le contrôleur Stimulus met à jour cette valeur à chaque clic.
            %>
                  <input type="hidden"
                   name="research[<%= criterion[:key] %>]"
                   value="<%= is_essential ? 3 : 0 %>"
                   data-wizard-essentials-target="hiddenField"
                   data-criterion="<%= criterion[:key] %>">
                </div>
              <% end %>
            </div>
            <div class="wizard-nav">
              <%# "Précédent" : lien GET vers l'étape précédente (pas de soumission) %>
              <%= link_to wizard_path(:details), class: "btn-wizard-prev" do %>
                <i class="fas fa-arrow-left" aria-hidden="true"></i>
                Précédent
              <% end %>
              <button type="submit" class="btn-wizard-next">
                Suivant
                <i class="fas fa-arrow-right" aria-hidden="true"></i>
              </button>
            </div>
          <% end %>
        </div>
      </div>
