<%#
  Composant city_card – représentation visuelle d'une ville candidate.

  Variables locales attendues :
    city    : instance de City (enrichie de `computed_score` via CityRankerService)
    index   : entier, rang dans le classement (commence à 1)
    search  : instance de Research ou GuestSearch

  Les liens et actions ("Trouver sur la carte", SeLoger) sont affichés en bas
  de la carte. Le rang (index) est propagé à "Trouver sur la carte" via ?rank=
  pour que la carte ville-unique réutilise le même marqueur numéroté.
%>
<%#
  Configuration des 6 critères disponibles avec leurs couleurs.
  Les couleurs reprennent exactement celles définies dans _research.html.erb
  pour assurer la cohérence visuelle entre le formulaire et les résultats.
  `score_method` est le nom de la méthode appelée sur l'objet City.
%>
<% city_criteria = [
  { key: :real_estate,         title: 'Immobilier',                 color: '#8D6E63', score_method: :real_estate_score },
  { key: :transport_network,   title: 'Transports',                 color: '#2E9EAD', score_method: :transport_network_score },
  { key: :health,              title: 'Santé',                      color: '#F48FB1', score_method: :health_score },
  { key: :commercial_life,     title: 'Commerce',                   color: '#FFB74D', score_method: :commercial_life_score },
  { key: :cultural_heritage,   title: 'Culture',                    color: '#9575CD', score_method: :cultural_heritage_score },
  { key: :leisures_and_sports, title: 'Sports & loisirs',           color: '#E57373', score_method: :leisures_sports_score },
  { key: :outdoor_living,      title: 'Vie au grand air',           color: '#558B2F', score_method: :outdoor_living_score },
  { key: :sunshine,            title: 'Ville ensoleillée',          color: '#FFCA28', score_method: :sunshine_score},
  { key: :job_market,          title: 'Ville d\'emploi',            color: '#B3E5FC', score_method: :job_market_score },
  { key: :nearest_big_city,    title: 'Métropole',                  color: '#FF8A65', score_method: :nearest_big_city_score},
  { key: :education,           title: 'Éducation',                  color: '#0288D1', score_method: :education_score }
] %>
<div class="city-card">
  <%# ── En-tête : rang + nom + localisation ─────────────────────────── %>
  <div class="city-card__header">
    <%# Médaillon de rang : indique la position dans le classement %>
    <span class="city-card__rank">#<%= index %></span>
    <div class="city-card__identity">
      <h3 class="city-card__name"><%= city.nom_com %></h3>
      <%# compact supprime les nil si nom_dep ou nom_reg manquent en base %>
      <span class="city-card__location">
        <%= [city.nom_dep, city.nom_reg].compact.join(' · ') %>
      </span>
    </div>
  </div>
  <%# ── Photo de la ville ──────────────────────────────────────────────────── %>
  <%#
    Si image_url est nil (ville jamais consultée avant, ou API indisponible),
    on affiche un bloc CSS placeholder pour conserver le gabarit de la carte.
    loading="lazy" : le navigateur ne charge l'image qu'au moment où la carte
    entre dans le viewport — améliore le temps de chargement initial.
  %>
  <% if city.image_url.present? %>
    <div class="city-card__photo">
      <%= image_tag city.image_url,
            alt:     "Vue de #{city.nom_com}",
            loading: "lazy" %>
      <%# Crédit Wikimedia Commons (licence Creative Commons) %>
      <span class="city-card__photo-credit">© Wikimedia Commons</span>
    </div>
  <% else %>
    <div class="city-card__photo-placeholder">
      <span class="city-card__photo-label">Photo à venir</span>
    </div>
  <% end %>
  <%# ── Jauges de scores par critère ────────────────────────────────── %>
  <%#
    On affiche les 6 critères disponibles pour toutes les villes.
    Le score (float 0-100 en base) est arrondi et présenté comme un pourcentage.
    .to_f.round protège contre un éventuel nil en base.
  %>
  <div class="city-card__scores">
    <% city_criteria.each do |criterion| %>
      <%#
        On lit la valeur brute AVANT tout cast : si elle est nil, la donnée est absente
        en base (seed incomplète). On affiche alors une barre grisée et "?" au lieu de "0%",
        ce qui serait trompeur pour l'utilisateur.
        &.round : opérateur safe-navigation, retourne nil si raw_score est nil.
      %>
      <% raw_score = city.public_send(criterion[:score_method]) %>
      <% score     = raw_score&.round %>
      <div class="city-card__score-row">
        <span class="city-card__score-label"><%= criterion[:title] %></span>
        <div class="city-card__gauge-track">
          <%#
            Largeur et couleur injectées en style inline.
            Si score est nil : largeur 0, couleur grise (#BDBDBD) pour signaler l'absence.
            role + aria-* pour l'accessibilité (lecteurs d'écran).
          %>
          <div class="city-card__gauge-fill"
               style="width: <%= score ? "#{score}%" : '0%' %>; background-color: <%= score ? criterion[:color] : '#BDBDBD' %>;"
               role="progressbar"
               aria-valuenow="<%= score || 0 %>"
               aria-valuemin="0"
               aria-valuemax="100">
          </div>
        </div>
        <span class="city-card__score-value"><%= score ? "#{score}%" : '?' %></span>
      </div>
    <% end %>
  </div>
  <%#
    Calcule les kinds de POI correspondant aux critères "essentiels" (valeur = 3)
    de la recherche. Seuls les critères ayant un kind de POI associé sont retenus
    (ex : real_estate n'a pas de POI dédié → exclu du mapping).
    Ces kinds sont passés en query param à maps#show pour filtrer l'affichage.
  %>
  <% poi_kind_mapping = {
       transport_network:   "transport",
       cultural_heritage:   "culture",
       health:              "health",
       commercial_life:     "commerce",
       leisures_and_sports: "sport",
       education:           "education"
     }
     essential_kinds = poi_kind_mapping.filter_map do |key, kind|
       kind if search.respond_to?(key) && search.public_send(key).to_i == 3
     end
     #
     # On propage le rang (index) à maps#show via le query param ?rank=
     # pour que la carte ville-unique puisse afficher le même marqueur coloré
     # + numéroté que sur la carte des 5 résultats.
     map_query_params = {}
     map_query_params[:kinds] = essential_kinds.join(",") if essential_kinds.any?
     city_map_url = map_path(city.id, map_query_params) %>

  <%# ── Actions ──────────────────────────────────────────────────────── %>
  <div class="city-card__actions">
    <%# Bouton "Trouver sur la carte" – ouvre la carte centrée sur cette ville
        avec uniquement les POIs des critères essentiels du user (?kinds=…) %>
    <%= link_to "Trouver sur la carte",
            city_map_url,
            class: "city-card__map-btn" %>
    <%#
      Lien SeLoger : secondaire visuellement (outline) pour ne pas concurrencer
      les actions principales. target="_blank" + rel="noopener noreferrer" :
      - _blank ouvre dans un nouvel onglet (l'utilisateur garde la page Move On)
      - noopener : empêche la page cible d'accéder à window.opener (sécurité)
      - noreferrer : n'envoie pas le Referer HTTP (confidentialité)
    %>
    <%= link_to seloger_url(city),
          target: "_blank",
          rel:    "noopener noreferrer",
          class:  "city-card__seloger-btn" do %>
      <svg class="city-card__seloger-icon" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2.5"
           aria-hidden="true">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
        <polyline points="9 22 9 12 15 12 15 22"/>
      </svg>
      SeLoger.com
    <% end %>
  </div>
</div>
