<%#
  Modale de confirmation de suppression — utilisée à la place de la boîte
  native du navigateur (window.confirm). Elle est déclenchée via l'override
  de Turbo.config.forms.confirm dans application.js.

  Les classes CSS (modal-content, btn-modal-danger…) sont définies dans
  app/assets/stylesheets/pages/_profile.scss pour rester dans la charte Move On.
%>
<div class="modal fade"
     id="confirmDeleteModal"
     tabindex="-1"
     aria-labelledby="confirmDeleteModalLabel"
     aria-modal="true"
     role="dialog">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title" id="confirmDeleteModalLabel">
          <%# Icône d'avertissement colorée en brun (--brown-primary) via _profile.scss %>
          <i class="fa-solid fa-triangle-exclamation"></i>
          Supprimer cette recherche
        </h5>
        <button type="button"
                class="btn-close"
                data-bs-dismiss="modal"
                aria-label="Fermer"></button>
      </div>

      <div class="modal-body">
        <p>Es-tu sûr(e) de vouloir supprimer cette recherche ?</p>
        <%# Avertissement secondaire — style plus discret via .modal-warning-text %>
        <p class="modal-warning-text">
          <i class="fa-solid fa-circle-info"></i>
          Cette action est irréversible. Toutes les données associées seront définitivement supprimées.
        </p>
      </div>

      <div class="modal-footer">
        <button type="button"
                class="btn btn-modal-cancel"
                data-bs-dismiss="modal">
          Annuler
        </button>
        <%# Ce bouton est ciblé par application.js pour résoudre la Promise Turbo %>
        <button type="button"
                class="btn btn-modal-danger"
                id="confirmDeleteBtn">
          <i class="fa-solid fa-trash"></i>
          Supprimer définitivement
        </button>
      </div>

    </div>
  </div>
</div>
