<%#
  Partial : carte d'un critère de recherche.

  Ce composant est affiché dans chacune des 3 sous-sections (essentiel, important, bonus),
  soit 33 instances au total pour 11 critères.
  Le contrôleur Stimulus "research-form" masque automatiquement toutes les copies d'un
  critère dès qu'il est sélectionné, quelle que soit la sous-section.

  Locals attendus :
    criterion  – Hash { key:, title:, color:, description: }
    section    – String : 'essential' | 'important' | 'bonus'
    research   – instance de Research ou GuestSearch (pour pré-remplir l'état éducation)
%>
<%#
  Mapping critère → classe Font Awesome (free solid tier).
  Défini ici plutôt que dans _research.html.erb (données presentationnelles).
  Font Awesome est chargé via la gem font-awesome-sass (@import "font-awesome" dans application.scss).
%>
<% criterion_icons = {
  'real_estate'         => 'fa-house',
  'transport_network'   => 'fa-train',
  'health'              => 'fa-stethoscope',
  'commercial_life'     => 'fa-store',
  'cultural_heritage'   => 'fa-landmark',
  'leisures_and_sports' => 'fa-dumbbell',
  'outdoor_living'      => 'fa-tree',
  'sunshine'            => 'fa-sun',
  'job_market'          => 'fa-briefcase',
  'near_big_city'       => 'fa-city',
  'education'           => 'fa-graduation-cap',
} %>
<%# On compose l'id unique de la checkbox pour relier le <label> (accessibilité) %>
<% checkbox_id = "criterion_#{criterion[:key]}_#{section}" %>
<%#
  saved_levels : niveaux d'éducation déjà en base (array en mode édition, [] sinon).
  Défini ici (hors du bloc if education) pour être accessible dans le footer également.
  Pour tous les critères hors éducation, c'est simplement [] — sans impact.
%>
<% saved_levels = criterion[:key] == 'education' ? (research.education_levels || []) : [] %>
<div class="criterion-card"
     data-research-form-target="card"
     data-criterion="<%= criterion[:key] %>"
     data-section="<%= section %>"
     data-title="<%= criterion[:title] %>"
     data-color="<%= criterion[:color] %>"
     style="--card-color: <%= criterion[:color] %>">
  <%# Bandeau de couleur en haut : repère visuel rapide du critère %>
  <div class="criterion-card-color-band"></div>
  <div class="criterion-card-body">
    <%# Titre du critère avec icône Font Awesome à gauche %>
    <p class="criterion-card-title">
      <% icon_class = criterion_icons[criterion[:key]] %>
      <% if icon_class %>
        <%#
          L'icône hérite de la couleur du critère (--card-color) pour une cohérence
          visuelle avec le bandeau de couleur en haut de la carte.
        %>
        <i class="fas <%= icon_class %> criterion-icon" aria-hidden="true"></i>
      <% end %>
      <%= criterion[:title] %>
    </p>
    <%# Bouton accordéon : déplie la description des sources et du calcul du score %>
    <button class="criterion-card-info-btn"
            type="button"
            data-action="click->research-form#toggleAccordion">
      En savoir plus ▾
    </button>
    <%# Contenu déroulant – caché par défaut (hidden = display:none natif HTML).
        On utilise le helper criterion_description (ApplicationHelper) pour
        obtenir la vraie description, plutôt que le lorem ipsum du hash local.
        Si la clé est inconnue côté helper, on retombe sur criterion[:description]. %>
    <div class="criterion-card-accordion" hidden>
      <p><%= criterion_description(criterion[:key]).presence || criterion[:description] %></p>
    </div>
  </div>
  <%# ─── Spécificité Éducation ───────────────────────────────────────────
      Ce bloc n'est rendu que pour le critère Éducation.
      L'utilisateur doit préciser ses niveaux scolaires AVANT de pouvoir
      cocher la checkbox. Cela garantit que la sélection est toujours précise.
  %>
  <% if criterion[:key] == 'education' %>
    <div class="education-selector">
      <p class="education-selector-label">Niveaux scolaires souhaités</p>
      <%# Zone injectée dynamiquement par Stimulus avec les tags de niveaux choisis %>
      <div class="education-inner-tags"
           data-research-form-target="educationTagsDisplay">
      </div>
      <div class="education-selector-controls wizard-education-controls">
        <%# Les options déjà sauvegardées sont désactivées dès le rendu HTML.
            Stimulus (updateEducationCards) maintient cet état synchronisé dynamiquement. %>
        <select data-research-form-target="educationSelect" class="wizard-education-select">
          <option value="">Choisir un niveau…</option>
          <option value="Petite enfance"   <%= 'disabled' if saved_levels.include?('Petite enfance') %>>Petite enfance (crèches, EAJE)</option>
          <option value="Premier degré"    <%= 'disabled' if saved_levels.include?('Premier degré') %>>Premier degré (écoles maternelles et élémentaires)</option>
          <option value="Second degré"     <%= 'disabled' if saved_levels.include?('Second degré') %>>Second degré (collèges et lycées)</option>
        </select>
        <button type="button"
          class="wizard-education-add-btn"
          data-action="click->research-form#addEducationTag">
          <i class="fas fa-plus" aria-hidden="true"></i>
          Ajouter
        </button>
      </div>
    </div>
  <% end %>
  <%# Pied de carte : checkbox de sélection du critère dans cette sous-section %>
  <div class="criterion-card-footer">
            <%#
      Pour Éducation : la checkbox est grisée si aucun niveau n'est encore choisi.
      En mode édition, saved_levels contient les niveaux déjà en base → checkbox active dès le rendu.
      Stimulus (updateEducationCheckboxes) maintient cet état synchronisé dynamiquement.
    %>
            <% education_can_select = criterion[:key] != 'education' || saved_levels.any? %>
            <div class="criterion-card-checkbox-wrapper <%= 'checkbox-disabled' unless education_can_select %>">
              <input type="checkbox"
             id="<%= checkbox_id %>"
             data-action="change->research-form#selectCriterion"
              data-criterion="<%= criterion[:key] %>"
              data-section="<%= section %>"
              <% if criterion[:key] == 'education' %>
                data-research-form-target="educationCheckbox"
                <%= 'disabled' unless education_can_select %>
              <% end %>>
              <%# Label dynamique selon la section %>
              <% section_labels = {
           'essential' => 'Essentiel pour moi',
           'important' => 'Important pour moi',
           'bonus'     => 'Bonus pour moi'
         } %>
              <label for="<%= checkbox_id %>"><%= section_labels[section] || 'Sélectionner' %></label>
            </div>
          </div>
        </div>
